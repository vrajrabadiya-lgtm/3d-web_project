PORT=5051

# MongoDB Atlas connection string
# Replace USER, PASSWORD, and CLUSTER with your values.
# If the password contains @, URL-encode it as %40
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/3d_builder_prod?retryWrites=true&w=majority&appName=Cluster0

# Redis connection URL for background processing
REDIS_URL=redis://127.0.0.1:6379

# Gmail SMTP (use a Google App Password, not your normal Gmail password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Vercel frontend URL (set this in Vercel dashboard environment variables)
CLIENT_URL=https://your-frontend.vercel.app
